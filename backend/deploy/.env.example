# Copy to `.env` on the VM and fill in real values. NEVER commit the real .env.
APP_ENV=production
PORT=8080

# MongoDB Atlas connection string (rotate the password if it was ever committed).
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/?retryWrites=true&w=majority
MONGODB_DB=freetokenspoker

# Signs identity JWTs. Use a long random value, e.g. `openssl rand -base64 48`.
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRY_HOURS=168

# Every frontend origin that may call the API / open a WebSocket.
CORS_ORIGINS=https://freetokenspoker.com,https://www.freetokenspoker.com,https://freetokenspoker.pages.dev

RATE_LIMIT_RPS=20
RATE_LIMIT_BURST=40
