# Copy to .env for local overrides. All values have sane defaults in config.go.
APP_ENV=development
PORT=8080

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=freetokenspoker

# Auth (email is identity only; this secret signs the identity JWT)
JWT_SECRET=TokensSpokerSecred678
JWT_EXPIRY_HOURS=168

# Comma-separated browser origin allowlist (frontend dev + preview)
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# Rate limiting (per client IP)
RATE_LIMIT_RPS=20
RATE_LIMIT_BURST=40
